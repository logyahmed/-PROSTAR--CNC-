{
  "version": 2,
  "name": "prostar-cnc",
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/services", "dest": "/services.html" },
    { "src": "/quote", "dest": "/quote.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
