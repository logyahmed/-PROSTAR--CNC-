{
  "version": 2,
  "name": "prostar-cnc",
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/$", "dest": "/index.html" },
    { "src": "/index(?:\\.html)?/?", "dest": "/index.html" },
    { "src": "/about(?:\\.html)?/?", "dest": "/about.html" },
    { "src": "/services(?:\\.html)?/?", "dest": "/services.html" },
    { "src": "/quote(?:\\.html)?/?", "dest": "/quote.html" },
    { "src": "/machines(?:\\.html)?/?", "dest": "/machines.html" },
    { "src": "/contact(?:\\.html)?/?", "dest": "/contact.html" },
    { "src": "/faq(?:\\.html)?/?", "dest": "/faq.html" },
    { "src": "/blog(?:\\.html)?/?", "dest": "/blog.html" },
    { "src": "/article(?:\\.html)?/?", "dest": "/article.html" },
    { "src": "/careers(?:\\.html)?/?", "dest": "/careers.html" },
    { "src": "/privacy(?:\\.html)?/?", "dest": "/privacy.html" },
    { "src": "/terms(?:\\.html)?/?", "dest": "/terms.html" }
  ]
}
