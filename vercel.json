{
  "version": 2,
  "name": "prostar-cnc",
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/services", "dest": "/services.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/maintenance", "dest": "/maintenance.html" },
    { "src": "/faq", "dest": "/faq.html" },
    { "src": "/quote", "dest": "/quote.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
